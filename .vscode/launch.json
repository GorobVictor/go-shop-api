{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Go: Launch (local)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/src/cmd/web",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Go: Launch Fake",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/src/cmd/fake-app",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Frontend: dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/fe-src",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Go + Frontend (local)",
      "configurations": ["Go: Launch (local)", "Frontend: dev"]
    }
  ]
}
